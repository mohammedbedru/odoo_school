<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Portal User Groups -->
    <record id="group_portal_student" model="res.groups">
        <field name="name">Portal Student</field>
        <field name="category_id" ref="base.module_category_hidden"/>
        <field name="implied_ids" eval="[(4, ref('base.group_portal'))]"/>
    </record>

    <record id="group_portal_parent" model="res.groups">
        <field name="name">Portal Parent</field>
        <field name="category_id" ref="base.module_category_hidden"/>
        <field name="implied_ids" eval="[(4, ref('base.group_portal'))]"/>
    </record>

    <!-- Record Rules for Students -->
    <record id="rule_student_own_record" model="ir.rule">
        <field name="name">Student: Own Record Only</field>
        <field name="model_id" ref="school_core.model_school_student"/>
        <field name="domain_force">[('user_id', '=', user.id)]</field>
        <field name="groups" eval="[(4, ref('group_portal_student'))]"/>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="False"/>
        <field name="perm_create" eval="False"/>
        <field name="perm_unlink" eval="False"/>
    </record>

    <record id="rule_student_own_attendance" model="ir.rule">
        <field name="name">Student: Own Attendance Only</field>
        <field name="model_id" ref="school_academic.model_school_attendance_line"/>
        <field name="domain_force">[('student_id.user_id', '=', user.id)]</field>
        <field name="groups" eval="[(4, ref('group_portal_student'))]"/>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="False"/>
        <field name="perm_create" eval="False"/>
        <field name="perm_unlink" eval="False"/>
    </record>

    <record id="rule_student_own_exam_marks" model="ir.rule">
        <field name="name">Student: Own Exam Marks Only</field>
        <field name="model_id" ref="school_academic.model_school_exam_mark"/>
        <field name="domain_force">[('student_id.user_id', '=', user.id)]</field>
        <field name="groups" eval="[(4, ref('group_portal_student'))]"/>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="False"/>
        <field name="perm_create" eval="False"/>
        <field name="perm_unlink" eval="False"/>
    </record>

    <record id="rule_student_own_report_card" model="ir.rule">
        <field name="name">Student: Own Report Cards Only</field>
        <field name="model_id" ref="school_academic.model_school_report_card"/>
        <field name="domain_force">[('student_id.user_id', '=', user.id)]</field>
        <field name="groups" eval="[(4, ref('group_portal_student'))]"/>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="False"/>
        <field name="perm_create" eval="False"/>
        <field name="perm_unlink" eval="False"/>
    </record>

    <record id="rule_student_own_fees" model="ir.rule">
        <field name="name">Student: Own Fees Only</field>
        <field name="model_id" ref="school_fees.model_school_student_fee"/>
        <field name="domain_force">[('student_id.user_id', '=', user.id)]</field>
        <field name="groups" eval="[(4, ref('group_portal_student'))]"/>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="False"/>
        <field name="perm_create" eval="False"/>
        <field name="perm_unlink" eval="False"/>
    </record>

    <!-- Record Rules for Parents -->
    <record id="rule_parent_children_records" model="ir.rule">
        <field name="name">Parent: Children Records Only</field>
        <field name="model_id" ref="school_core.model_school_student"/>
        <field name="domain_force">[('parent_ids.user_id', '=', user.id)]</field>
        <field name="groups" eval="[(4, ref('group_portal_parent'))]"/>
