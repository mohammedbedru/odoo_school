<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_school_promotion_wizard_form" model="ir.ui.view">
        <field name="name">school.promotion.wizard.form</field>
        <field name="model">school.promotion.wizard</field>
        <field name="arch" type="xml">
            <form string="Promote Students">
                <sheet>
                    <p class="oe_grey">
                        Select the source and destination sections. Click 'Load Students' to see the list of active students available for promotion.
                    </p>
                    <group>
                        <group>
                            <field name="from_section_id" options="{'no_create': True}"/>
                            <button name="action_load_students" 
                                    string="Load Students" 
                                    type="object" 
                                    class="btn-secondary" 
                                    invisible="not from_section_id"/>
                        </group>
                        <group>
                            <field name="to_section_id" options="{'no_create': True}"/>
                        </group>
                    </group>

                    <notebook invisible="not student_ids">
                        <page string="Students to Promote" name="students">
                            <field name="student_ids">
                                <list create="0">
                                    <field name="student_code"/>
                                    <field name="name"/>
                                    <field name="grade_id"/>
                                    <field name="gender"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
                <footer>
                    <button name="action_promote" 
                            string="Promote Students" 
                            type="object" 
                            class="btn-primary" 
                            confirm="Are you sure you want to move the selected students to the new section and grade?"
                            invisible="not student_ids"
                            data-hotkey="q"/>
                    <button string="Cancel" class="btn-secondary" special="cancel" data-hotkey="z"/>
                </footer>
            </form>
        </field>
    </record>

    <!-- Window Action -->
    <record id="action_school_promotion_wizard" model="ir.actions.act_window">
        <field name="name">Promote Students</field>
        <field name="res_model">school.promotion.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>

    <!-- Menu Item -->
    <menuitem id="menu_school_promotion_wizard" 
              name="Student Promotion" 
              parent="menu_school_wizards" 
              action="action_school_promotion_wizard" 
              sequence="50"/>

</odoo>