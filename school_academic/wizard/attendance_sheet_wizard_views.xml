<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_school_attendance_sheet_wizard_form" model="ir.ui.view">
        <field name="name">school.attendance.sheet.wizard.form</field>
        <field name="model">school.attendance.sheet.wizard</field>
        <field name="arch" type="xml">
            <form string="Generate Attendance Sheet">
                <group>
                    <group>
                        <field name="date"/>
                        <field name="section_id" options="{'no_create': True}"/>
                    </group>
                    <group>
                        <field name="teacher_id" options="{'no_create': True}"/>
                    </group>
                </group>
                <footer>
                    <button name="action_generate_attendance" string="Generate Sheet" type="object" class="btn-primary" data-hotkey="q"/>
                    <button string="Cancel" class="btn-secondary" special="cancel" data-hotkey="z"/>
                </footer>
            </form>
        </field>
    </record>

    <!-- Action to open the Wizard -->
    <record id="action_school_attendance_sheet_wizard" model="ir.actions.act_window">
        <field name="name">Generate Attendance</field>
        <field name="res_model">school.attendance.sheet.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field> <!-- This makes it a popup -->
    </record>

    <!-- Menu Item to trigger the Wizard -->
    <menuitem id="menu_school_attendance_wizard" 
              name="Mark Attendance" 
              parent="menu_school_wizards" 
              action="action_school_attendance_sheet_wizard" 
              sequence="25"/>
</odoo>