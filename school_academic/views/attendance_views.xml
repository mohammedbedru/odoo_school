<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- list (List) View -->
    <record id="view_school_attendance_list" model="ir.ui.view">
        <field name="name">school.attendance.list</field>
        <field name="model">school.attendance</field>
        <field name="arch" type="xml">
            <list string="Attendance Logs" decoration-info="state == 'draft'" decoration-success="state == 'confirmed'">
                <field name="date"/>
                <field name="name"/>
                <field name="section_id"/>
                <field name="teacher_id"/>
                <field name="state" widget="badge" 
                       decoration-info="state == 'draft'" 
                       decoration-success="state == 'confirmed'"/>
            </list>
        </field>
    </record>

    <!-- Form View -->
    <record id="view_school_attendance_form" model="ir.ui.view">
        <field name="name">school.attendance.form</field>
        <field name="model">school.attendance</field>
        <field name="arch" type="xml">
            <form string="Attendance Record">
                <header>
                    <button name="action_confirm" string="Confirm" type="object" 
                            class="oe_highlight" invisible="state != 'draft'"/>
                    <button name="action_set_draft" string="Reset to Draft" type="object" 
                            invisible="state != 'confirmed'"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,confirmed"/>
                    <button name="%(school_academic.action_report_attendance_sheet)d"
                            type="action"
                            string="Print Attendance"
                            class="btn-secondary"/>

                </header>
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name" readonly="1"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="date" readonly="state == 'confirmed'"/>
                            <field name="section_id" options="{'no_create': True}" readonly="state == 'confirmed'"/>
                        </group>
                        <group>
                            <field name="teacher_id" options="{'no_create': True}" readonly="state == 'confirmed'"/>
                            <field name="company_id" groups="base.group_multi_company" options="{'no_create': True}"/>
                        </group>
                    </group>

                    <notebook>
                        <page string="Attendance Lines" name="lines">
                            <field name="line_ids" readonly="state == 'confirmed'">
                                <list editable="bottom" create="0" delete="0">
                                    <field name="student_id" readonly="1"/>
                                    <!-- Radio widget allows one-click marking (Present/Absent/Late) -->
                                    <field name="status" widget="radio" options="{'horizontal': true}"/>
                                    <field name="note" placeholder="Reason for absence..."/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <!-- Search View -->
    <record id="view_school_attendance_search" model="ir.ui.view">
        <field name="name">school.attendance.search</field>
        <field name="model">school.attendance</field>
        <field name="arch" type="xml">
            <search string="Search Attendance">
                <field name="section_id"/>
                <field name="teacher_id"/>
                <field name="date"/>
                <separator/>
                <filter string="Today" name="today" domain="[('date', '=', context_today().strftime('%Y-%m-%d'))]"/>
                <filter string="Draft" name="draft" domain="[('state', '=', 'draft')]"/>
                <filter string="Confirmed" name="confirmed" domain="[('state', '=', 'confirmed')]"/>
                <group expand="0" string="Group By">
                    <filter string="Section" name="group_by_section" context="{'group_by': 'section_id'}"/>
                    <filter string="Date" name="group_by_date" context="{'group_by': 'date:day'}"/>
                    <filter string="Status" name="group_by_state" context="{'group_by': 'state'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Action -->
    <record id="action_school_attendance" model="ir.actions.act_window">
        <field name="name">Attendance Records</field>
        <field name="res_model">school.attendance</field>
        <field name="view_mode">list,form</field>
        <field name="context">{'search_default_today': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No attendance records yet!
            </p>
            <p>
                Use the "Mark Attendance" wizard to generate a sheet for your class.
            </p>
        </field>
    </record>

    <!-- Menu Item -->
    <!-- (Assuming menu_school_management was defined in previous steps) -->
    <menuitem id="menu_school_attendance_list" 
              name="Attendance Logs" 
              parent="menu_school_academics" 
              action="action_school_attendance" 
              sequence="26"/>

</odoo>