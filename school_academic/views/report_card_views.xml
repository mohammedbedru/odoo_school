<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Report Card list (List) View -->
    <record id="view_school_report_card_list" model="ir.ui.view">
        <field name="name">school.report.card.list</field>
        <field name="model">school.report.card</field>
        <field name="arch" type="xml">
            <list string="Report Cards" decoration-info="state == 'draft'" decoration-success="state == 'published'">
                <field name="name"/>
                <field name="student_id"/>
                <field name="section_id"/>
                <field name="term"/>
                <field name="academic_year_id"/>
                <field name="average" string="Avg Mark" avg="Global Average"/>
                <field name="state" widget="badge" 
                       decoration-info="state == 'draft'" 
                       decoration-warning="state == 'confirmed'" 
                       decoration-success="state == 'published'"/>
            </list>
        </field>
    </record>

    <!-- Report Card Form View -->
    <record id="view_school_report_card_form" model="ir.ui.view">
        <field name="name">school.report.card.form</field>
        <field name="model">school.report.card</field>
        <field name="arch" type="xml">
            <form string="Report Card">
                <header>
                    <!-- Action Buttons -->
                    <button name="action_generate_from_exams" string="Fetch Marks" type="object" 
                            class="oe_highlight" invisible="state != 'draft'"
                            confirm="This will clear existing lines and fetch marks from all published exams. Continue?"/>
                    
                    <button name="action_confirm" string="Confirm" type="object" 
                            class="oe_highlight" invisible="state != 'draft'"/>
                    
                    <button name="action_publish" string="Publish" type="object" 
                            class="oe_highlight" invisible="state != 'confirmed'"/>
                    
                    <button name="action_set_draft" string="Reset to Draft" type="object" 
                            invisible="state == 'draft'"/>

                    <button name="%(school_academic.action_report_report_card)d"
                            type="action"
                            string="Print Report Card"
                            class="btn-secondary"/>

                    <field name="state" widget="statusbar" statusbar_visible="draft,confirmed,published"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name" readonly="1"/>
                        </h1>
                    </div>
                    <group>
                        <group string="Student &amp; Class">
                            <field name="student_id" options="{'no_create': True}" readonly="state != 'draft'"/>
                            <field name="section_id" readonly="1" force_save="1"/>
                            <field name="company_id" groups="base.group_multi_company" options="{'no_create': True}"/>
                        </group>
                        <group string="Academic Term">
                            <field name="term" readonly="state != 'draft'"/>
                            <field name="academic_year_id" options="{'no_create': True}" readonly="state != 'draft'"/>
                        </group>
                    </group>

                    <group name="totals" class="mt-2">
                        <group>
                            <field name="total" force_save="1" string="Total Marks"/>
                            <field name="average" force_save="1" string="Average Percentage"/>
                        </group>
                    </group>

                    <notebook>
                        <page string="Subject Grades" name="lines">
                            <field name="line_ids" readonly="1"> <!--readonly="state != 'draft'" -->
                                <list>
                                    <field name="subject_id" options="{'no_create': True}"/>
                                    <field name="teacher_id" options="{'no_create': True}"/>
                                    <field name="quiz_mark"/>
                                    <field name="quiz_max" optional="hide"/>
                                    <field name="mid_mark"/>
                                    <field name="mid_max" optional="hide"/>
                                    <field name="final_mark"/>
                                    <field name="final_max" optional="hide"/>
                                    <field name="assignment_mark"/>
                                    <field name="assignment_max" optional="hide"/>
                                    <field name="total_mark" readonly="1" force_save="1"/>
                                    <field name="total_max" readonly="1" optional="hide" force_save="1"/>
                                    <field name="percentage" readonly="1" force_save="1"/>
                                    <field name="grade" readonly="1" force_save="1"/>
                                    <field name="remark"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <!-- Report Card Search View -->
    <record id="view_school_report_card_search" model="ir.ui.view">
        <field name="name">school.report.card.search</field>
        <field name="model">school.report.card</field>
        <field name="arch" type="xml">
            <search string="Search Report Cards">
                <field name="student_id"/>
                <field name="section_id"/>
                <field name="academic_year_id"/>
                <separator/>
                <filter string="Draft" name="draft" domain="[('state', '=', 'draft')]"/>
                <filter string="Published" name="published" domain="[('state', '=', 'published')]"/>
                <group expand="0" string="Group By">
                    <filter string="Student" name="group_by_student" context="{'group_by': 'student_id'}"/>
                    <filter string="Section" name="group_by_section" context="{'group_by': 'section_id'}"/>
                    <filter string="Term" name="group_by_term" context="{'group_by': 'term'}"/>
                    <filter string="Academic Year" name="group_by_year" context="{'group_by': 'academic_year_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Report Card Action -->
    <record id="action_school_report_card" model="ir.actions.act_window">
        <field name="name">Report Cards</field>
        <field name="res_model">school.report.card</field>
        <field name="view_mode">list,form</field>
        <field name="context">{'search_default_group_by_section': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Generate student report cards.
            </p>
            <p>
                You can pull marks directly from published exams using the 'Fetch Marks' button.
            </p>
        </field>
    </record>

    <!-- Menu Item -->
    <menuitem id="menu_school_report_card" 
              name="Report Cards" 
              parent="menu_school_report_cards" 
              action="action_school_report_card" 
              sequence="40"/>

</odoo>