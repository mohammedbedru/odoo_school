<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
    <t t-name="school_api.PasswordToggleField" owl="1">
        <div class="d-flex align-items-center gap-2">
            <input 
                t-if="!props.readonly"
                type="text"
                class="o_input"
                t-att-value="props.record.data[props.name]"
                t-on-change="(ev) => props.record.update({[props.name]: ev.target.value})"
                t-att-placeholder="props.placeholder"
                t-att-readonly="props.readonly"
            />
            <span 
                t-else=""
                class="o_field_char"
                t-esc="displayValue"
            />
            <button 
                t-if="props.readonly and props.record.data[props.name]"
                class="btn btn-link p-0 ms-2"
                t-on-click="() => this.toggleVisibility()"
                title="Toggle visibility"
                type="button"
            >
                <i t-attf-class="fa {{iconClass}}"/>
            </button>
            <button 
                t-if="props.readonly and props.record.data[props.name]"
                class="btn btn-link p-0"
                t-on-click="() => navigator.clipboard.writeText(props.record.data[props.name])"
                title="Copy to clipboard"
                type="button"
            >
                <i class="fa fa-clipboard"/>
            </button>
        </div>
    </t>
</templates>
