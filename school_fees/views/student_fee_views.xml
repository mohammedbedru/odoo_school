<odoo>
    <record id="view_student_fee_list" model="ir.ui.view">
        <field name="name">school.student.fee.list</field>
        <field name="model">school.student.fee</field>
        <field name="arch" type="xml">
            <list decoration-danger="is_overdue" decoration-success="payment_state == 'paid'">
                <field name="student_id"/>
                <field name="academic_year_id"/>
                <field name="term"/>
                <field name="due_date"/>
                <field name="amount_total"/>
                <field name="amount_paid"/>
                <field name="amount_due"/>
                <field name="has_sibling_discount" optional="hide"/>
                <field name="sibling_discount_amount" optional="hide"/>
                <field name="is_overdue" optional="hide"/>
                <field name="days_overdue" optional="hide"/>
                <field name="state" widget="badge" 
                       decoration-info="state == 'draft'" 
                       decoration-warning="state == 'invoiced'" 
                       decoration-success="state == 'paid'"/>
                <field name="payment_state" widget="badge"
                       decoration-danger="payment_state == 'not_paid'"
                       decoration-warning="payment_state == 'partial'"
                       decoration-success="payment_state == 'paid'"/>
            </list>
        </field>
    </record>

    <record id="view_student_fee_form" model="ir.ui.view">
        <field name="name">school.student.fee.form</field>
        <field name="model">school.student.fee</field>
        <field name="arch" type="xml">
            <form string="Student Fee">
                <header>
                    <button name="action_generate_invoice"
                            type="object"
                            string="Generate Invoice"
                            class="btn-primary"
                            invisible="invoice_id"/>

                    <button name="action_view_invoice"
                            type="object"
                            string="View Invoice"
                            class="btn-secondary"
                            invisible="not invoice_id"/>
                    
                    <button name="action_apply_late_fee"
                            type="object"
                            string="Apply Late Fee"
                            class="btn-warning"
                            invisible="not is_overdue or late_fee_applied or not invoice_id"
                            confirm="Apply late fee to this invoice?"/>

                    <field name="state" widget="statusbar"
                           statusbar_visible="draft,invoiced,paid,cancelled"/>
                </header>

                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_view_invoice"
                                type="object"
                                class="oe_stat_button"
                                icon="fa-file-text-o"
                                invisible="not invoice_id">
                            <div class="o_field_widget o_stat_info">
                                <span class="o_stat_text">View</span>
                                <span class="o_stat_text">Invoice</span>
                            </div>
                        </button>
                    </div>

                    <div class="oe_title">
                        <h1>
                            <field name="display_name" readonly="1"/>
                        </h1>
                    </div>

                    <group>
                        <group string="Student Information">
                            <field name="student_id" options="{'no_create': True}"/>
                            <field name="academic_year_id" options="{'no_create': True}"/>
                            <field name="term"/>
                        </group>
                        <group string="Fee Structure">
                            <field name="structure_id" options="{'no_create': True}"/>
                            <field name="due_date"/>
                        </group>
                    </group>

                    <group string="Discount &amp; Scholarship">
                        <group>
                            <field name="discount_type"/>
                            <field name="discount_value" invisible="not discount_type"/>
                            <field name="discount_amount" readonly="1"/>
                        </group>
                        <group>
                            <field name="scholarship_id" options="{'no_create': True}"/>
                            <field name="scholarship_amount" readonly="1"/>
                        </group>
                    </group>

                    <group string="Sibling Discount">
                        <group>
                            <field name="apply_sibling_discount"/>
                            <field name="has_sibling_discount" readonly="1"/>
                            <field name="sibling_count" readonly="1" invisible="not has_sibling_discount"/>
                        </group>
                        <group>
                            <field name="sibling_discount_percent" readonly="1" invisible="not has_sibling_discount"/>
                            <field name="sibling_discount_amount" readonly="1" widget="monetary"/>
                        </group>
                    </group>

                    <group string="Late Fee">
                        <group>
                            <field name="apply_late_fee"/>
                            <field name="late_fee_amount" readonly="1"/>
                            <field name="late_fee_applied" readonly="1"/>
                        </group>
                    </group>

                    <group string="Amount Summary">
                        <group>
                            <field name="amount_total" readonly="1" widget="monetary"/>
                            <field name="amount_paid" readonly="1" widget="monetary"/>
                            <field name="amount_due" readonly="1" widget="monetary"/>
                        </group>
                        <group>
                            <field name="is_overdue" readonly="1"/>
                            <field name="days_overdue" readonly="1" invisible="not is_overdue"/>
                            <field name="invoice_id" readonly="1"/>
                            <field name="payment_state" readonly="1"/>
                        </group>
                    </group>
                </sheet>

                <chatter/>
            </form>
        </field>
    </record>

    <record id="view_student_fee_search" model="ir.ui.view">
        <field name="name">school.student.fee.search</field>
        <field name="model">school.student.fee</field>
        <field name="arch" type="xml">
            <search>
                <field name="student_id"/>
                <field name="academic_year_id"/>
                <field name="term"/>
                <separator/>
                <filter string="Unpaid" name="unpaid" domain="[('payment_state', '!=', 'paid')]"/>
                <filter string="Overdue" name="overdue" domain="[('is_overdue', '=', True)]"/>
                <filter string="Paid" name="paid" domain="[('payment_state', '=', 'paid')]"/>
                <filter string="Partially Paid" name="partial" domain="[('payment_state', '=', 'partial')]"/>
                <separator/>
                <filter string="With Sibling Discount" name="sibling_discount" domain="[('has_sibling_discount', '=', True)]"/>
                <filter string="With Scholarship" name="scholarship" domain="[('scholarship_id', '!=', False)]"/>
                <separator/>
                <filter string="Draft" name="draft" domain="[('state', '=', 'draft')]"/>
                <filter string="Invoiced" name="invoiced" domain="[('state', '=', 'invoiced')]"/>
                <group expand="0" string="Group By">
                    <filter string="Student" name="group_student" context="{'group_by': 'student_id'}"/>
                    <filter string="Academic Year" name="group_year" context="{'group_by': 'academic_year_id'}"/>
                    <filter string="Term" name="group_term" context="{'group_by': 'term'}"/>
                    <filter string="Payment Status" name="group_payment" context="{'group_by': 'payment_state'}"/>
                    <filter string="Due Date" name="group_due_date" context="{'group_by': 'due_date:month'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_student_fees" model="ir.actions.act_window">
        <field name="name">Student Fees</field>
        <field name="res_model">school.student.fee</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="menu_student_fees"
              name="Student Fees"
              parent="school_fees.menu_school_fees_operations"
              action="action_student_fees"
              sequence="10"/>
</odoo>
