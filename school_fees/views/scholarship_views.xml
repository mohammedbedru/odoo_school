<odoo>
    <!-- Scholarship List View -->
    <record id="view_scholarship_list" model="ir.ui.view">
        <field name="name">school.scholarship.list</field>
        <field name="model">school.scholarship</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="code"/>
                <field name="scholarship_type"/>
                <field name="discount_type"/>
                <field name="discount_value"/>
                <field name="student_count"/>
                <field name="active" widget="boolean_toggle"/>
            </list>
        </field>
    </record>

    <!-- Scholarship Form View -->
    <record id="view_scholarship_form" model="ir.ui.view">
        <field name="name">school.scholarship.form</field>
        <field name="model">school.scholarship</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_view_students"
                                type="object"
                                class="oe_stat_button"
                                icon="fa-users">
                            <field name="student_count" widget="statinfo" string="Students"/>
                        </button>
                    </div>

                    <widget name="web_ribbon" title="Archived" bg_color="text-bg-danger" invisible="active"/>

                    <div class="oe_title">
                        <label for="name"/>
                        <h1>
                            <field name="name" placeholder="e.g. Merit Scholarship 2024"/>
                        </h1>
                    </div>

                    <group>
                        <group string="Basic Information">
                            <field name="code"/>
                            <field name="scholarship_type"/>
                            <field name="active" invisible="1"/>
                        </group>
                        <group string="Discount Configuration">
                            <field name="discount_type"/>
                            <field name="discount_value"/>
                            <field name="max_amount" invisible="discount_type != 'percent'"/>
                            <field name="currency_id" invisible="1"/>
                        </group>
                    </group>

                    <group string="Eligibility Criteria">
                        <field name="min_grade_percentage"/>
                        <field name="applicable_grades" widget="many2many_tags"/>
                    </group>

                    <group string="Description">
                        <field name="description" nolabel="1" placeholder="Describe the scholarship criteria and benefits..."/>
                    </group>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <!-- Scholarship Search View -->
    <record id="view_scholarship_search" model="ir.ui.view">
        <field name="name">school.scholarship.search</field>
        <field name="model">school.scholarship</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="code"/>
                <field name="scholarship_type"/>
                <separator/>
                <filter string="Active" name="active" domain="[('active', '=', True)]"/>
                <filter string="Archived" name="archived" domain="[('active', '=', False)]"/>
                <group expand="0" string="Group By">
                    <filter string="Type" name="group_type" context="{'group_by': 'scholarship_type'}"/>
                    <filter string="Discount Type" name="group_discount" context="{'group_by': 'discount_type'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Scholarship Action -->
    <record id="action_scholarships" model="ir.actions.act_window">
        <field name="name">Scholarships</field>
        <field name="res_model">school.scholarship</field>
        <field name="view_mode">list,form</field>
        <field name="context">{'search_default_active': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create a scholarship program
            </p>
            <p>
                Define scholarships that can be applied to student fees.
            </p>
        </field>
    </record>

    <!-- Menu Item -->
    <menuitem id="menu_scholarships"
              name="Scholarships"
              parent="school_fees.menu_school_fees_config"
              action="action_scholarships"
              sequence="20"/>
</odoo>
