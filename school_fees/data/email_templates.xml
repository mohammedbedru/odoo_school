<odoo>
    <!-- Payment Reminder Email Template (7 days before due) -->
    <record id="email_template_payment_reminder" model="mail.template">
        <field name="name">Fee Payment Reminder</field>
        <field name="model_id" ref="model_school_student_fee"/>
        <field name="subject">Payment Reminder: Fee Due on {{ object.due_date }}</field>
        <field name="email_from">{{ (object.company_id.email or user.email_formatted) }}</field>
        <field name="email_to">{{ ','.join(object.student_id.parent_ids.mapped('email')) if object.student_id.parent_ids else object.student_id.email }}</field>
        <field name="body_html" type="html">
            <div style="font-family: Arial, sans-serif; max-width: 600px; margin: 0 auto;">
                <div style="background-color: #1a4d80; color: white; padding: 20px; text-align: center;">
                    <h2 style="margin: 0;">Fee Payment Reminder</h2>
                </div>
                
                <div style="padding: 20px; background-color: #f8f9fa;">
                    <p>Dear Parent/Guardian,</p>

                    <p>This is a friendly reminder that the following fee payment is due soon:</p>
                    
                    <table style="width: 100%; border-collapse: collapse; margin: 20px 0;">
                        <tr style="background-color: #e8f4f8;">
                            <td style="padding: 10px; border: 1px solid #ddd;"><strong>Student Name:</strong></td>
                            <td style="padding: 10px; border: 1px solid #ddd;">
                                <t t-out="object.student_id.name"/>
                            </td>
                        </tr>
                        <tr>
                            <td style="padding: 10px; border: 1px solid #ddd;"><strong>Academic Year:</strong></td>
                            <td style="padding: 10px; border: 1px solid #ddd;">
                                <t t-out="object.academic_year_id.name"/>
                            </td>
                        </tr>
                        <tr style="background-color: #e8f4f8;">
                            <td style="padding: 10px; border: 1px solid #ddd;"><strong>Term:</strong></td>
                            <td style="padding: 10px; border: 1px solid #ddd;">
                                <span t-field="object.term"/> <!-- t-field for selection field -->
                            </td>
                        </tr>
                        <tr>
                            <td style="padding: 10px; border: 1px solid #ddd;"><strong>Due Date:</strong></td>
                            <td style="padding: 10px; border: 1px solid #ddd; color: #d9534f; font-weight: bold;">
                                <t t-out="object.due_date"/>
                            </td>
                        </tr>
                        <tr style="background-color: #e8f4f8;">
                            <td style="padding: 10px; border: 1px solid #ddd;"><strong>Amount Due:</strong></td>
                            <td style="padding: 10px; border: 1px solid #ddd; font-size: 18px; font-weight: bold;">
                                <t t-out="format_amount(object.amount_total, object.currency_id)"/>
                            </td>
                        </tr>
                    </table>
                    
                    <div style="text-align: center; margin: 30px 0;">
                        <a t-attf-href="/my/invoices/{{ object.invoice_id.id }}" 
                        style="background-color: #1a4d80; color: white; padding: 12px 30px; text-decoration: none; border-radius: 5px; display: inline-block;">
                            View Invoice
                        </a>
                    </div>
                    
                    <p>Best regards,<br/>
                    <strong><t t-out="object.company_id.name"/></strong></p>
                </div>
            </div>
        </field>
    </record>

    <!-- Overdue Payment Email Template -->
    <record id="email_template_payment_overdue" model="mail.template">
        <field name="name">Fee Payment Overdue Notice</field>
        <field name="model_id" ref="model_school_student_fee"/>
        <field name="subject">URGENT: Overdue Fee Payment - {{ object.student_id.name }}</field>
        <field name="email_from">{{ (object.company_id.email or user.email_formatted) }}</field>
        <field name="email_to">{{ ','.join(object.student_id.parent_ids.mapped('email')) if object.student_id.parent_ids else object.student_id.email }}</field>
        <field name="body_html" type="html">
            <div style="font-family: Arial, sans-serif; max-width: 600px; margin: 0 auto;">
                <div style="background-color: #d9534f; color: white; padding: 20px; text-align: center;">
                    <h2 style="margin: 0;">⚠️ OVERDUE PAYMENT NOTICE</h2>
                </div>
                
                <div style="padding: 20px; background-color: #f8f9fa;">
                    <p>Dear Parent/Guardian,</p>
                    
                    <p style="color: #d9534f; font-weight: bold;">
                        This is an urgent notice that the following fee payment is now OVERDUE:
                    </p>
                    
                    <table style="width: 100%; border-collapse: collapse; margin: 20px 0;">
                        <tr style="background-color: #ffe6e6;">
                            <td style="padding: 10px; border: 1px solid #ddd;"><strong>Student Name:</strong></td>
                            <td style="padding: 10px; border: 1px solid #ddd;">
                                <t t-out="object.student_id.name"/>
                            </td>
                        </tr>
                        <tr>
                            <td style="padding: 10px; border: 1px solid #ddd;"><strong>Academic Year:</strong></td>
                            <td style="padding: 10px; border: 1px solid #ddd;">
                                <t t-out="object.academic_year_id.name"/>
                            </td>
                        </tr>
                        <tr style="background-color: #ffe6e6;">
                            <td style="padding: 10px; border: 1px solid #ddd;"><strong>Term:</strong></td>
                            <td style="padding: 10px; border: 1px solid #ddd;">
                                <span t-field="object.term"/> <!-- t-field for selection field -->
                            </td>
                        </tr>
                        <tr>
                            <td style="padding: 10px; border: 1px solid #ddd;"><strong>Due Date:</strong></td>
                            <td style="padding: 10px; border: 1px solid #ddd; color: #d9534f; font-weight: bold;">
                                <t t-out="object.due_date"/>
                            </td>
                        </tr>
                        <tr style="background-color: #ffe6e6;">
                            <td style="padding: 10px; border: 1px solid #ddd;"><strong>Days Overdue:</strong></td>
                            <td style="padding: 10px; border: 1px solid #ddd; color: #d9534f; font-weight: bold;">
                                <t t-out="object.days_overdue"/> days
                            </td>
                        </tr>
                        <tr>
                            <td style="padding: 10px; border: 1px solid #ddd;"><strong>Amount Due:</strong></td>
                            <td style="padding: 10px; border: 1px solid #ddd; font-size: 18px; font-weight: bold; color: #d9534f;">
                                <t t-out="format_amount(object.amount_total, object.currency_id)"/>
                            </td>
                        </tr>
                        <t t-if="object.late_fee_amount &gt; 0">
                            <tr style="background-color: #ffe6e6;">
                                <td style="padding: 10px; border: 1px solid #ddd;"><strong>Late Fee:</strong></td>
                                <td style="padding: 10px; border: 1px solid #ddd; font-weight: bold;">
                                    <t t-out="format_amount(object.late_fee_amount, object.currency_id)"/>
                                </td>
                            </tr>
                        </t>
                    </table>
                    
                    <div style="background-color: #fff3cd; border-left: 4px solid #ffc107; padding: 15px; margin: 20px 0;">
                        <p style="margin: 0; font-weight: bold;">⚠️ Important Notice:</p>
                        <p style="margin: 10px 0 0 0;">
                            Late fees may be applied to overdue payments. Please settle this payment immediately to avoid additional charges.
                        </p>
                    </div>
                    
                    <div style="text-align: center; margin: 30px 0;">
                        <a t-attf-href="/my/invoices/{{ object.invoice_id.id }}" 
                           style="background-color: #d9534f; color: white; padding: 12px 30px; text-decoration: none; border-radius: 5px; display: inline-block;">
                            Pay Now
                        </a>
                    </div>
                    
                    <p style="margin-top: 30px;">
                        If you have any questions or need to discuss payment arrangements, please contact our accounts office immediately.
                    </p>
                    
                    <p>Best regards,<br/>
                    <strong><t t-out="object.company_id.name"/></strong><br/>
                    <t t-out="object.company_id.phone or ''"/><br/>
                    <t t-out="object.company_id.email or ''"/></p>
                </div>
                
                <div style="background-color: #333; color: white; padding: 15px; text-align: center; font-size: 12px;">
                    <p style="margin: 0;">This is an automated message. Please do not reply to this email.</p>
                </div>
            </div>
        </field>
    </record>

   <!-- Payment Completed Email Template (triggerd by autmoation)-->
    <record id="email_template_payment_completed" model="mail.template">
        <field name="name">Fee Payment Completed Message</field>
        <field name="model_id" ref="school_fees.model_school_student_fee"/>
        <field name="subject">Payment Received: {{ object.student_id.name }} - {{ object.academic_year_id.name }}</field>
        <field name="email_from">{{ (object.company_id.email_formatted or user.email_formatted) }}</field>
        <field name="email_to">{{ ','.join(object.student_id.parent_ids.mapped('email')) if object.student_id.parent_ids else object.student_id.email }}</field>
        <field name="body_html" type="html">
            <div style="font-family: Arial, sans-serif; max-width: 600px; margin: 0 auto;">
                <!-- Header: Changed to Green (#28a745) for Success -->
                <div style="background-color: #28a745; color: white; padding: 20px; text-align: center;">
                    <h2 style="margin: 0;">✅ PAYMENT SUCCESSFUL</h2>
                </div>
                
                <div style="padding: 20px; background-color: #f8f9fa;">
                    <p>Dear Parent/Guardian,</p>
                    
                    <p style="color: #28a745; font-weight: bold;">
                        Thank you! We have successfully received your fee payment. 
                        Please find the details of the transaction below:
                    </p>
                    
                    <table style="width: 100%; border-collapse: collapse; margin: 20px 0;">
                        <tr style="background-color: #eafaf1;">
                            <td style="padding: 10px; border: 1px solid #ddd;"><strong>Student Name:</strong></td>
                            <td style="padding: 10px; border: 1px solid #ddd;">
                                <t t-out="object.student_id.name"/>
                            </td>
                        </tr>
                        <tr>
                            <td style="padding: 10px; border: 1px solid #ddd;"><strong>Academic Year:</strong></td>
                            <td style="padding: 10px; border: 1px solid #ddd;">
                                <t t-out="object.academic_year_id.name"/>
                            </td>
                        </tr>
                        <tr style="background-color: #eafaf1;">
                            <td style="padding: 10px; border: 1px solid #ddd;"><strong>Term:</strong></td>
                            <td style="padding: 10px; border: 1px solid #ddd;">
                                <span t-field="object.term"/>
                            </td>
                        </tr>
                        <tr>
                            <td style="padding: 10px; border: 1px solid #ddd;"><strong>Invoice Reference:</strong></td>
                            <td style="padding: 10px; border: 1px solid #ddd;">
                                <t t-out="object.invoice_id.name"/>
                            </td>
                        </tr>
                        <tr style="background-color: #eafaf1;">
                            <td style="padding: 10px; border: 1px solid #ddd;"><strong>Total Paid:</strong></td>
                            <td style="padding: 10px; border: 1px solid #ddd; font-size: 18px; font-weight: bold; color: #28a745;">
                                <t t-out="format_amount(object.amount_paid, object.currency_id)"/>
                            </td>
                        </tr>
                    </table>
                    
                    <!-- Confirmation Message Box -->
                    <div style="background-color: #d4edda; border-left: 4px solid #28a745; padding: 15px; margin: 20px 0;">
                        <p style="margin: 0; font-weight: bold; color: #155724;">Confirmed:</p>
                        <p style="margin: 10px 0 0 0;">
                            Your account has been updated, and this term's fees are now marked as <strong>Paid</strong>. 
                            You can view or download your official receipt using the button below.
                        </p>
                    </div>
                    
                    <div style="text-align: center; margin: 30px 0;">
                        <a t-attf-href="/my/invoices/{{ object.invoice_id.id }}" 
                           style="background-color: #28a745; color: white; padding: 12px 30px; text-decoration: none; border-radius: 5px; display: inline-block;">
                            View Receipt
                        </a>
                    </div>
                    
                    <p style="margin-top: 30px;">
                        If you have any questions regarding this payment, please feel free to contact the accounts office.
                    </p>
                    
                    <p>Best regards,<br/>
                    <strong><t t-out="object.company_id.name"/></strong><br/>
                    <t t-out="object.company_id.phone or ''"/><br/>
                    <t t-out="object.company_id.email or ''"/></p>
                </div>
                
                <div style="background-color: #333; color: white; padding: 15px; text-align: center; font-size: 12px;">
                    <p style="margin: 0;">This is an automated confirmation of payment. Please keep this for your records.</p>
                </div>
            </div>
        </field>
    </record>

    </odoo>
