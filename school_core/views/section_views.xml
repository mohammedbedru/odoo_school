<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- list (List) View -->
    <record id="view_school_section_list" model="ir.ui.view">
        <field name="name">school.section.list</field>
        <field name="model">school.section</field>
        <field name="arch" type="xml">
            <list string="Sections">
                <field name="full_name"/>
                <field name="grade_id"/>
                <field name="class_teacher_id"/>
                <field name="student_count" string="Enrolled"/>
                <field name="capacity"/>
                <!-- Optional: color indicator if capacity is full -->
                <field name="company_id" groups="base.group_multi_company" optional="hide"/>
            </list>
        </field>
    </record>

    <!-- Form View -->
    <record id="view_school_section_form" model="ir.ui.view">
        <field name="name">school.section.form</field>
        <field name="model">school.section</field>
        <field name="arch" type="xml">
            <form string="Section">
                <sheet>
                    <!-- Smart Button for Students -->
                    <div class="oe_button_box" name="button_box">
                        <!-- Find this button in view_school_section_form -->
                        <button name="%(action_school_student)d" 
                                type="action" 
                                class="oe_stat_button" 
                                icon="fa-users"
                                context="{'search_default_section_id': id, 'default_section_id': id}">
                            <field name="student_count" widget="statinfo" string="Students"/>
                        </button>
                    </div>

                    <div class="oe_title">
                        <label for="full_name" string="Section Name"/>
                        <h1>
                            <field name="full_name" readonly="1"/>
                        </h1>
                    </div>

                    <group>
                        <group string="General Information">
                            <field name="grade_id" options="{'no_create_edit': True}"/>
                            <field name="name" placeholder="e.g. A, B or North"/>
                            <field name="class_teacher_id" options="{'no_create': True}"/>
                        </group>
                        <group string="Capacity &amp; Admin">
                            <field name="capacity"/>
                            <field name="student_count"/>
                            <field name="company_id" groups="base.group_multi_company"/>
                        </group>
                    </group>

                    <notebook>
                        <page string="Students List" name="students">
                            <field name="student_ids" readonly="1">
                                <list>
                                    <field name="student_code"/>
                                    <field name="name"/>
                                    <field name="gender"/>
                                    <field name="status"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Search View -->
    <record id="view_school_section_search" model="ir.ui.view">
        <field name="name">school.section.search</field>
        <field name="model">school.section</field>
        <field name="arch" type="xml">
            <search string="Search Sections">
                <field name="name"/>
                <field name="full_name"/>
                <field name="grade_id"/>
                <field name="class_teacher_id"/>
                <separator/>
                <filter string="Full Capacity" name="full" domain="[('student_count', '>=', 'capacity')]"/>
                <group expand="0" string="Group By">
                    <filter string="Grade" name="group_by_grade" context="{'group_by': 'grade_id'}"/>
                    <filter string="Teacher" name="group_by_teacher" context="{'group_by': 'class_teacher_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Action -->
    <record id="action_school_section" model="ir.actions.act_window">
        <field name="name">Sections</field>
        <field name="res_model">school.section</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create sections for your grades (e.g., Grade 10 - Section A).
            </p>
        </field>
    </record>

    <!-- Menu Item -->
    <menuitem id="menu_school_section" 
              name="Sections" 
              parent="menu_school_config" 
              action="action_school_section" 
              sequence="20"/>

</odoo>