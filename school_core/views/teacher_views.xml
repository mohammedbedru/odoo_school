<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- list (List) View -->
    <record id="view_school_teacher_list" model="ir.ui.view">
        <field name="name">school.teacher.list</field>
        <field name="model">school.teacher</field>
        <field name="arch" type="xml">
            <list string="Teachers">
                <field name="name"/>
                <field name="employee_id"/>
                <field name="phone"/>
                <field name="email"/>
                <field name="company_id" groups="base.group_multi_company"/>
            </list>
        </field>
    </record>

    <!-- Form View -->
    <record id="view_school_teacher_form" model="ir.ui.view">
        <field name="name">school.teacher.form</field>
        <field name="model">school.teacher</field>
        <field name="arch" type="xml">
            <form string="Teacher">
                <sheet>
                    <widget name="web_ribbon" title="Archived" bg_color="bg-danger" invisible="active"/>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1>
                            <field name="name" placeholder="Teacher Name"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="employee_id" options="{'no_create': True}"/>
                            <field name="partner_id"/>
                            <field name="active" invisible="1"/>
                        </group>
                        <group>
                            <field name="email" widget="email"/>
                            <field name="phone" widget="phone"/>
                            <field name="company_id" groups="base.group_multi_company" options="{'no_create': True}"/>
                        </group>
                    </group>
                </sheet>
                <!-- Chatter for mail.thread and mail.activity.mixin -->
                <Chatter/>
            </form>
        </field>
    </record>

    <!-- Search View -->
    <record id="view_school_teacher_search" model="ir.ui.view">
        <field name="name">school.teacher.search</field>
        <field name="model">school.teacher</field>
        <field name="arch" type="xml">
            <search string="Search Teachers">
                <field name="name"/>
                <field name="employee_id"/>
                <field name="email"/>
                <separator/>
                <filter string="Archived" name="inactive" domain="[('active', '=', False)]"/>
                <group expand="0" string="Group By">
                    <filter string="Company" name="group_by_company" context="{'group_by': 'company_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Window Action -->
    <record id="action_school_teacher" model="ir.actions.act_window">
        <field name="name">Teachers</field>
        <field name="res_model">school.teacher</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_school_teacher_search"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create your first teacher!
            </p>
        </field>
    </record>

    <!-- Menus -->
    <menuitem id="menu_school_teacher" 
              name="Teachers" 
              parent="menu_school_root" 
              action="action_school_teacher" 
              sequence="10"/>

</odoo>