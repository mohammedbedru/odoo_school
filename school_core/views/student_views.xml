<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- list (List) View -->
    <record id="view_school_student_list" model="ir.ui.view">
        <field name="name">school.student.list</field>
        <field name="model">school.student</field>
        <field name="arch" type="xml">
            <list string="Students" decoration-info="status == 'draft'" decoration-success="status == 'active'">
                <field name="student_code"/>
                <field name="name"/>
                <field name="grade_id"/>
                <field name="section_id"/>
                <field name="age"/>
                <field name="gender"/>
                <field name="status" widget="badge" 
                       decoration-info="status == 'draft'" 
                       decoration-warning="status == 'enrolled'"
                       decoration-success="status == 'active'"
                       decoration-muted="status == 'graduated'"/>
            </list>
        </field>
    </record>

    <!-- Kanban View (Great for records with photos) -->
    <record id="view_school_student_kanban" model="ir.ui.view">
        <field name="name">school.student.kanban</field>
        <field name="model">school.student</field>
        <field name="arch" type="xml">
            <kanban default_group_by="grade_id" sample="1">
                <field name="id"/>
                <field name="name"/>
                <field name="student_code"/>
                <field name="grade_id"/>
                <templates>
                    <t t-name="kanban-box">
                        <div class="oe_kanban_global_click o_kanban_record_has_image_fill">
                            <field name="photo" widget="image" class="o_kanban_image_fill_left" 
                                   options="{'zoom': true, 'background': true, 'prevent_ability_unhide': true}"/>
                            <div class="oe_kanban_details">
                                <strong class="o_kanban_record_title"><field name="name"/></strong>
                                <div class="o_kanban_record_subtitle">
                                    <field name="student_code"/>
                                </div>
                                <ul>
                                    <li>Grade: <field name="grade_id"/></li>
                                    <li>Age: <field name="age"/></li>
                                </ul>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <!-- Form View -->
    <record id="view_school_student_form" model="ir.ui.view">
        <field name="name">school.student.form</field>
        <field name="model">school.student</field>
        <field name="arch" type="xml">
            <form string="Student">
                <header>
                    <field name="status" widget="statusbar" options="{'clickable': '1'}" statusbar_visible="draft,enrolled,active,graduated"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_view_parents" type="object" class="oe_stat_button" icon="fa-users" invisible="parent_count == 0">
                            <field name="parent_count" widget="statinfo" string="Parents"/>
                        </button>
                    </div>
                    <field name="photo" widget="image" class="oe_avatar" options="{'preview_image': 'photo'}"/>
                    <div class="oe_title">
                        <h1>
                            <field name="student_code" placeholder="STUD001"/>
                        </h1>
                        <h2>
                            <field name="name" placeholder="Student Name"/>
                        </h2>
                    </div>
                    <group>
                        <group string="Academic Information">
                            <field name="grade_id" options="{'no_create': True}"/>
                            <field name="section_id" domain="[('grade_id', '=', grade_id)]"/>
                            <field name="academic_year_id"/>
                            <field name="admission_date"/>
                        </group>
                        <group string="Personal Information">
                            <field name="gender"/>
                            <field name="dob"/>
                            <field name="age"/>
                            <field name="email"/>
                            <field name="phone"/>
                            <field name="partner_id" string="Related Contact"/>
                            <field name="company_id" groups="base.group_multi_company"/>
                        </group>
                    </group>
                    
                    <group string="Address">
                        <field name="address" nolabel="1"/>
                    </group>
                    
                    <notebook>
                        <page string="Parents/Guardians" name="parents">
                            <field name="parent_ids" widget="many2many">
                                <list>
                                    <field name="name"/>
                                    <field name="relation"/>
                                    <field name="phone"/>
                                    <field name="email"/>
                                    <field name="is_emergency_contact"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <!-- Search View -->
    <record id="view_school_student_search" model="ir.ui.view">
        <field name="name">school.student.search</field>
        <field name="model">school.student</field>
        <field name="arch" type="xml">
            <search string="Search Students">
                <field name="name" filter_domain="['|', ('name', 'ilike', self), ('student_code', 'ilike', self)]"/>
                <field name="grade_id"/>
                <filter string="Active Students" name="active_students" domain="[('status', '=', 'active')]"/>
                <filter string="Applicants" name="applicants" domain="[('status', '=', 'draft')]"/>
                <separator/>
                <filter string="Archived" name="inactive" domain="[('active', '=', False)]"/>
                <group expand="0" string="Group By">
                    <filter string="Status" name="group_by_status" context="{'group_by': 'status'}"/>
                    <filter string="Grade" name="group_by_grade" context="{'group_by': 'grade_id'}"/>
                    <filter string="Gender" name="group_by_gender" context="{'group_by': 'gender'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Action -->
    <record id="action_school_student" model="ir.actions.act_window">
        <field name="name">Students</field>
        <field name="res_model">school.student</field>
        <field name="view_mode">kanban,list,form</field>
        <field name="context">{'search_default_active_students': 1, 'search_default_group_by_grade': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Admit your first student!
            </p>
        </field>
    </record>

    <!-- Menu Item -->
    <menuitem id="menu_school_student" 
              name="Students" 
              parent="menu_school_root" 
              action="action_school_student" 
              sequence="20"/>

</odoo>