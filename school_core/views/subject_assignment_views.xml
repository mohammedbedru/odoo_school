<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- list (List) View -->
    <record id="view_school_subject_assignment_list" model="ir.ui.view">
        <field name="name">school.subject.assignment.list</field>
        <field name="model">school.subject.assignment</field>
        <field name="arch" type="xml">
            <list string="Subject Assignments">
                <field name="section_id"/>
                <field name="subject_id"/>
                <field name="teacher_id"/>
                <field name="hours_per_week" sum="Total Weekly Hours"/>
            </list>
        </field>
    </record>

    <!-- Form View -->
    <record id="view_school_subject_assignment_form" model="ir.ui.view">
        <field name="name">school.subject.assignment.form</field>
        <field name="model">school.subject.assignment</field>
        <field name="arch" type="xml">
            <form string="Subject Assignment">
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="display_name"/>
                        </h1>
                    </div>
                    <group>
                        <group string="Assignment Details">
                            <field name="section_id" options="{'no_create': True}"/>
                            <!-- Domain ensures you only pick subjects relevant to the section's grade -->
                            <field name="subject_id" 
                                   options="{'no_create': True}"/>
                        </group>
                        <group string="Faculty &amp; Schedule">
                            <field name="teacher_id" options="{'no_create': True}"/>
                            <field name="hours_per_week"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Pivot View (Great for Workload Analysis) -->
    <record id="view_school_subject_assignment_pivot" model="ir.ui.view">
        <field name="name">school.subject.assignment.pivot</field>
        <field name="model">school.subject.assignment</field>
        <field name="arch" type="xml">
            <pivot string="Assignment Analysis" sample="1">
                <field name="teacher_id" type="row"/>
                <field name="section_id" type="col"/>
                <field name="hours_per_week" type="measure"/>
            </pivot>
        </field>
    </record>

    <!-- Search View -->
    <record id="view_school_subject_assignment_search" model="ir.ui.view">
        <field name="name">school.subject.assignment.search</field>
        <field name="model">school.subject.assignment</field>
        <field name="arch" type="xml">
            <search string="Search Assignments">
                <field name="teacher_id"/>
                <field name="section_id"/>
                <field name="subject_id"/>
                <group expand="0" string="Group By">
                    <filter string="Teacher" name="group_by_teacher" context="{'group_by': 'teacher_id'}"/>
                    <filter string="Section" name="group_by_section" context="{'group_by': 'section_id'}"/>
                    <filter string="Subject" name="group_by_subject" context="{'group_by': 'subject_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Action -->
    <record id="action_school_subject_assignment" model="ir.actions.act_window">
        <field name="name">Subject Assignments</field>
        <field name="res_model">school.subject.assignment</field>
        <field name="view_mode">list,form,pivot</field>
        <field name="context">{'search_default_group_by_section': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Assign a teacher to a subject within a section.
            </p>
        </field>
    </record>

    <!-- Menu Item -->
    <!-- Placing this under a new "Academics" or "Management" menu -->
    <menuitem id="menu_school_management" 
              name="Management" 
              parent="menu_school_root" 
              sequence="15"/>

    <menuitem id="menu_school_subject_assignment" 
              name="Subject Assignments" 
              parent="menu_school_management" 
              action="action_school_subject_assignment" 
              sequence="10"/>

</odoo>